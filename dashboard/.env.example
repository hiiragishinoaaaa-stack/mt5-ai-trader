# このファイルを .env.local にコピーして値を設定してください(.env.localはgit管理対象外)。
# ここで設定するのは、Settings画面の「AI判断ロジック」「発注設定」が接続する
# Python側の設定API(mt5_ai_trader/settings_server.py)の接続先のみ。
# Home/Trade/Analytics/Settingsのそれ以外の項目はまだモックのため、この設定の
# 影響を受けない。

# settings_server.pyのURL。未設定の場合は http://localhost:8787 を使う
# (PC上のブラウザからDashboardを開く場合のみ有効)。
# スマホなど別端末からDashboardを開く場合は、必ずPCのLAN IPを指定すること。
# 例: VITE_SETTINGS_API_URL=http://192.168.1.10:8787
VITE_SETTINGS_API_URL=http://localhost:8787

# settings_server.py側で SETTINGS_API_TOKEN を設定した場合のみ、同じ値をここに
# 設定する(未設定なら空のままでよい)。
VITE_SETTINGS_API_TOKEN=
