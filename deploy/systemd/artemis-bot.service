[Unit]
Description=ARTEMIS AI trading bot loop (main.py)
After=network.target artemis-settings-server.service

[Service]
Type=simple
User=__ARTEMIS_USER__
WorkingDirectory=__ARTEMIS_HOME__/mt5_ai_trader
ExecStart=__ARTEMIS_HOME__/mt5_ai_trader/.venv/bin/python __ARTEMIS_HOME__/mt5_ai_trader/main.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
