# このファイルを .env にコピーして値を設定してください。
# .env はデモ口座の認証情報を含むため、絶対にコミットしないこと(.gitignoreで除外済み)。

# --- MT5デモ口座 接続情報 ---
MT5_LOGIN=12345678
MT5_PASSWORD=your_demo_password
MT5_SERVER=YourBroker-Demo
# MT5ターミナルの実行ファイルパス(自動検出できない場合のみ指定)
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# --- 取引対象 ---
SYMBOL=USDJPY
TIMEFRAME=M15
BARS_COUNT=100

# --- インジケーター設定 ---
EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9

# --- AI判断エンジン ---
# rule_based | openai | claude (openai/claudeは未実装。ai_engine.py参照)
AI_ENGINE=rule_based

# --- 実行制御 ---
LOOP_INTERVAL_SECONDS=60

# --- ログ ---
LOG_LEVEL=INFO
