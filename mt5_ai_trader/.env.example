# このファイルを .env にコピーして値を設定してください。
# EAブリッジ方式に切り替えたため、MT5のログインID/パスワードをPython側で
# 保持する必要はない(EAは既にログイン済みのMT5ターミナル内で動作するため)。

# --- EAブリッジ(ファイル連携)設定 ---
# EA(ea/ARTEMIS_Bridge.mq5)が書き出すJSONファイルのパス。
# 未指定の場合、Windowsの %APPDATA%\MetaQuotes\Terminal\Common\Files\ 配下
# (EAの既定の書き出し先と同じ場所)を自動的に使うため、通常は指定不要。
# MARKET_DATA_FILE_PATH=C:\Users\your_name\AppData\Roaming\MetaQuotes\Terminal\Common\Files\artemis_market_data.json
# EAの書き込みが止まっていないかを判定する許容遅延(秒)。EAのInpUpdateIntervalSec
# (既定1秒)より十分大きい値にすること。
MARKET_DATA_MAX_STALENESS_SECONDS=30

# --- Phase 3: 口座情報・ポジション(Dashboardの残高/ポジション表示) ---
# 未指定の場合、MARKET_DATA_FILE_PATHと同じ共有フォルダを自動的に使う。
# ACCOUNT_STATE_FILE_PATH=C:\Users\your_name\AppData\Roaming\MetaQuotes\Terminal\Common\Files\artemis_account_state.json
ACCOUNT_STATE_MAX_STALENESS_SECONDS=30

# --- Phase 4: 取引履歴(Dashboardの注文履歴/統計表示) ---
# 未指定の場合、MARKET_DATA_FILE_PATHと同じ共有フォルダを自動的に使う。
# TRADE_HISTORY_FILE_PATH=C:\Users\your_name\AppData\Roaming\MetaQuotes\Terminal\Common\Files\artemis_trade_history.json
TRADE_HISTORY_MAX_STALENESS_SECONDS=60
# main.pyが各サイクルの判断をここへ書き出す(Dashboard表示用、MT5非依存)。
# 未指定の場合、mt5_ai_trader/artemis_ai_status.json を使う。
# AI_STATUS_FILE_PATH=./artemis_ai_status.json
AI_STATUS_MAX_STALENESS_SECONDS=120

# --- Phase 2: 発注設定 ---
# ENABLE_ORDERSとDEMO_ONLYの両方が明示的にtrueでない限り発注リクエストは
# 一切送出されない(既定はどちらもfalse)。ENABLE_ORDERSは「発注そのものを
# 行うか」、DEMO_ONLYは「対象口座がデモであること」を表す独立した設定
# (Dashboard Settingsの「発注設定」から別々に変更できる)。
# trueにする場合は、MT5側のEAプロパティでも InpEnableOrders=true にし、
# かつ実際にデモ口座へログインしていることを確認すること。
# 一部ブローカー(XM/XMTrading等)ではACCOUNT_TRADE_MODEがデモ口座を
# 正しく報告しないことがある。その場合はEA側のInpConfirmedDemoAccountに
# 自分のデモ口座番号を設定する(README.mdの既知の問題の項を参照)。
# 詳細はREADME.mdの「Phase 2: デモ口座への自動発注」を参照。
ENABLE_ORDERS=false
DEMO_ONLY=false
ORDER_VOLUME=0.01
# SL/TPはシンボルのpoint単位で指定する(価格そのものではない)。0以下でSL/TPなし。
SL_POINTS=200
TP_POINTS=400
# 未指定の場合、MARKET_DATA_FILE_PATHと同じ共有フォルダを自動的に使う。
# ORDER_REQUEST_FILE_PATH=C:\Users\your_name\AppData\Roaming\MetaQuotes\Terminal\Common\Files\artemis_order_request.json
# ORDER_RESULT_FILE_PATH=C:\Users\your_name\AppData\Roaming\MetaQuotes\Terminal\Common\Files\artemis_order_result.json
# EAが発注リクエストを処理し、結果ファイルを書き出すまでの最大待ち時間(秒)。
ORDER_RESULT_WAIT_SECONDS=10

# --- 発注テスト用モード ---
# AIの判断条件(EMA/RSI/MACD)が揃うのを待たずに、MT5への発注〜SL/TP設定〜
# 結果JSONまでの一連の流れだけを確認したい場合に使う。DEMO_ONLY=trueの
# 場合のみ有効。詳細はREADME.mdの「発注テスト用モード」を参照。
# BUY / SELL / WAIT / 空欄(通常運転、既存のAI判断ロジックのまま)
FORCE_SIGNAL=
# trueにすると、--once の指定有無に関わらず起動後1サイクルだけ実行して
# 終了する。FORCE_SIGNALと組み合わせて使うことを想定している。
TEST_ORDER_ONCE=false

# --- 取引対象 ---
# EA側のInpSymbol / InpTimeframe(MT5にEAを追加する際の入力パラメータ)と
# 必ず一致させること。一致しない場合はmarket_feed.pyがエラーにする。
SYMBOL=USDJPY
TIMEFRAME=M15
BARS_COUNT=100

# --- インジケーター設定 ---
EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9
# エントリーの厳しさのプリセット名(記録用。数値はRSI_OVERBOUGHT/OVERSOLDに
# 反映される。conservative=65/35, balanced=70/30, aggressive=80/20)。
ENTRY_STRICTNESS=balanced

# --- AI判断エンジン ---
# rule_based | openai | claude (openai/claudeは未実装。ai_engine.py参照)
AI_ENGINE=rule_based

# --- 実行制御 ---
LOOP_INTERVAL_SECONDS=60

# --- ログ ---
LOG_LEVEL=INFO

# --- ボットの起動/停止(DashboardのSTART/STOP/EMERGENCY STOP) ---
# RUNNING | STOPPED | EMERGENCY_STOPPED。RUNNING以外の場合、main.pyは
# プロセスとしては動き続けるが判断・発注を行わない。DashboardのHome画面から
# 変更するのが基本で、ここは初期値の指定用。
BOT_RUN_STATE=RUNNING

# --- Discord通知(取引ごとの通知) ---
# 両方(DISCORD_ENABLED=true かつ DISCORD_WEBHOOK_URLに実際のURL)を設定
# しない限り通知は送信されない。DashboardのSettings画面からも変更できる。
DISCORD_ENABLED=false
# Discordのチャンネル設定 > 連携サービス > Webhook から取得したURLを設定する。
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_ON_TRADE=true
DISCORD_NOTIFY_ON_ERROR=true

# --- Dashboardからの設定変更(settings_server.py) ---
# ORDER_VOLUME/SL_POINTS/TP_POINTS/TIMEFRAME/LOOP_INTERVAL_SECONDS/
# RSI_OVERBOUGHT/RSI_OVERSOLD/EMA_FAST_PERIOD/EMA_SLOW_PERIOD/
# ENTRY_STRICTNESS/ENABLE_ORDERS/DEMO_ONLY は、.envの代わりに
# config.json(settings_server.py経由でDashboardから書き込み)でも変更できる。
# config.jsonの場所。既定は mt5_ai_trader/config.json (.gitignore対象)。
# CONFIG_JSON_PATH=./config.json
# Dashboard(スマホ含む)からアクセスできるよう既定で全インターフェースに
# 待受する。信頼できるローカルネットワーク以外には公開しないこと。
SETTINGS_SERVER_HOST=0.0.0.0
SETTINGS_SERVER_PORT=8787
# 設定すると、settings_server.pyへのリクエストに
# `Authorization: Bearer <token>` ヘッダーが必須になる(推奨、任意)。
# DashboardのVITE_SETTINGS_API_TOKENにも同じ値を設定すること。
SETTINGS_API_TOKEN=
